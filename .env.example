# Environment Variables untuk FR Spoof Detector
# Copy file ini ke .env dan sesuaikan dengan kebutuhan

# Python
PYTHONUNBUFFERED=1
PYTHONPATH=/app

# FastAPI
LOG_LEVEL=info
# debug / info / warning / error / critical

# Database (jika diperlukan)
# DATABASE_URL=sqlite:///./test.db

# API Settings
MAX_UPLOAD_SIZE=104857600  # 100MB in bytes
REQUEST_TIMEOUT=300

# Model Settings
MODEL_CONFIDENCE_THRESHOLD=0.5

# Uvicorn
UVICORN_WORKERS=4
# Sesuaikan dengan jumlah CPU cores

# Memory & Performance
PYTHONOPTIMIZE=2
